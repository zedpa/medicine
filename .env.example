# 复制为 .env 并填入。.env 已被 .gitignore 忽略, 不要提交到仓库。
# LLM 后端(三选一; 都不填则走「直接模式」, 输入即药材名):
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# 网页端口
PORT=8501

# 账号授权（spec-004）。密钥仅放此处，勿提交。
# Cookie 加密 key（免登态签名）；务必设长随机串，更换会使所有人需重登：
AUTH_COOKIE_KEY=please-change-to-a-long-random-string
# 首次启动且账号库为空时，用以下凭据种入一个 admin（之后可删除该两行）：
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-strong-Pwd1!
# 可选：把现存（spec-004 之前的）历史一次性归给某用户：
# HISTORY_LEGACY_OWNER=admin
